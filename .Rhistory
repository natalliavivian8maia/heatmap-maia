library(tidyverse)
library(emmeans)
library(openxlsx)
library(car) #para o teste de levene
library (showtext)
font_add_google(name = "Montserrat", family = "montserrat-light", regular.wt = 300)
GSH_R <- GSH_R %>%
mutate(
Temperatura = factor(Temperatura),
Fenantreno = factor(Fenantreno)
)
GSH_R <- GSH_R %>%
mutate(
# ordem das concentrações
Fenantreno = fct_relevel(Fenantreno, "Controle", "10", "100"),
# ordem das temperaturas
Temperatura = fct_relevel(Temperatura, "27", "29", "31")
)
GSH_R$Fenantreno <- factor(
GSH_R$Fenantreno,
levels = c("Controle", "10", "100"),
labels = c("Control", "10", "100")
)
install.packages("ARTool")
library(ARTool)
modelo_art <- art(GSH ~ Temperatura * Fenantreno, data = GSH_R)
anova(modelo_art)
library(emmeans)
emmeans(modelo_art, pairwise ~ Temperatura * Fenantreno)
emm <- emmeans(modelo, ~ Temperatura * Fenantreno)
modelo_art <- art(GSH ~ Temperatura * Fenantreno, data = GSH_R)
modelo_interacao <- artlm(modelo_art, "Temperatura:Fenantreno")
emmeans(modelo_interacao, pairwise ~ Temperatura * Fenantreno)
modelo_art <- art(GSH ~ Temperatura * Fenantreno, data = GSH_R)
modelo_interacao <- artlm(modelo_art, "Temperatura:Fenantreno")
View(modelo_art)
artlm() → depois emmeans()
