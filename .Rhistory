library(pwr)
library(ggplot2)
# Tamanhos de amostra
n_values <- seq(15, 90, by = 15)
# Calcular poder do teste para cada n
power_values <- sapply(n_values, function(n) {
pwr.t.test(n = n, d = 0.5, sig.level = 0.05,
type = "two.sample", alternative = "two.sided")$power
})
df_power <- data.frame(
n = n_values,
power = power_values
)
ggplot(df_power, aes(x = n, y = power)) +
geom_line(color = "blue", size = 1.2) +
geom_hline(yintercept = 0.8, linetype = "dashed", color = "red") +
scale_x_continuous(limits = c(20, 100), breaks = seq(20, 100, by = 20)) +
scale_y_continuous(limits = c(0.2, 0.8), breaks = seq(0.2, 0.8, by = 0.2)) +
labs(
title = "Curva de Poder para teste t bilateral",
x = "Tamanho da Amostra (n)",
y = "Poder do Teste (1 - β)"
) +
theme_minimal(base_size = 14)
#Aqui é o mais atual com o eixo da escala x e y até o final bonitinho
ggplot(df_power, aes(x = n, y = power)) +
geom_line(color = "blue", size = 1.2) +
geom_point(color = "blue", size = 2.5) + #se quiser tirar esses pontos da tua curva, é só tu remover essa linha
geom_hline(yintercept = 0.8, linetype = "dashed", color = "red") +
scale_x_continuous(breaks = seq(20, 100, by = 10)) +
scale_y_continuous(breaks = seq(0.2, 0.9, by = 0.1)) +
coord_cartesian(xlim = c(20, 100), ylim = c(0.2, 0.9)) +
labs(
title = "Curva de Poder para teste t bilateral",
x = "Tamanho da Amostra (n)",
y = "Poder do Teste (1 - β)"
) +
theme_minimal(base_size = 14)
