n_values <- seq(10, 90, by = 5)
effect_sizes <- sapply(n_values, function(n) {
uniroot(function(d) pwr.t.test(n = n, d = NULL, sig.level = 0.05, power = 0.8, type = "two.sample")$power - 0.8,
c(0.01, 2))$root
})
df_detectable <- data.frame(n = n_values, effect_size = effect_sizes)
ggplot(df_detectable, aes(x = n, y = effect_size)) +
geom_line() +
geom_hline(yintercept = 0.5, linetype = "dashed") +  # exemplo
geom_vline(xintercept = df_detectable$n[which.min(abs(df_detectable$effect_size - 0.5))], linetype = "dotted") +
labs(x = "Número de Réplicas (n)", y = "Tamanho de Efeito Detectável")
