effect_sizes <- sapply(n_values, function(n) {
uniroot(function(d) {
pwr.t.test(n = n, d = d, sig.level = 0.05, power = NULL, type = "two.sample")$power - 0.8
}, interval = c(0.01, 2))$root
})
df_detectable <- data.frame(n = n_values, effect_size = effect_sizes)
ggplot(df_detectable, aes(x = n, y = effect_size)) +
geom_line() +
geom_point() +
geom_hline(yintercept = 0.5, linetype = "dashed", color = "red") +
geom_vline(
xintercept = df_detectable$n[which.min(abs(df_detectable$effect_size - 0.5))],
linetype = "dotted", color = "blue"
) +
labs(
x = "Número de Réplicas (n)",
y = "Tamanho de Efeito Detectável",
title = "Detectabilidade do Efeito em Função do Número de Réplicas"
) +
theme_minimal()
