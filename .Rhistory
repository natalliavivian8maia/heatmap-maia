url_dados %>%
read_delim(
skip = 10,
delim = ";",
na = "null",
locale = locale(decimal_mark = ","),
) -> dados_campos
dados_campos <-
dados_campos %>%
separate(
col = `Data Medicao`,
into = c("Ano", "Mês", "Dia"),
sep = "-",
remove = FALSE
) %>%
mutate(
...7 = NULL,
Dia = NULL,
Ano = as.numeric(Ano),
Mês = as.numeric(Mês)
) %>%
rename_with(
.fn = ~ c("Data", "Ano", "Mês", "Prec",
"Tmax", "Tmed", "Tmin", "Vmed")
)
View(dados_campos)
